# —— ฝั่งเว็บ (Vite) ——
# เปิดโหมดดึงเคสจาก API + Turso/R2
VITE_USE_CLOUD=true
# ว่างไว้ = ใช้ path เดียวกับหน้าเว็บ (แนะนำให้ตั้ง proxy ใน vite ไปที่พอร์ต API)
# VITE_API_URL=https://your-api.example.com

# —— ฝั่งเซิร์ฟเวอร์ (server/.env หรือ root .env ที่โหลดเอง) ——
PORT=8787

# Turso
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# URL สาธารณะของบัคเก็ต (เช่น Custom Domain หรือ r2.dev) — ห้ามมี / ท้าย
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev

# จำกัดจำนวนเคสในระบบ (แต่ละเคส = 1 รูปใน R2) — เว้นว่าง = ไม่จำกัด
# MAX_CASES=12

# รหัสผ่านล็อกอินผู้ดูแลอย่างเดียว (ไม่มี username) + คีย์เรียก API แก้ไขเคส (ตั้งยาว ๆ สุ่มเอง)
ADMIN_WEB_PASSWORD=neuro
ADMIN_API_KEY=เปลี่ยนเป็นสตริงยาวสุ่ม

# CORS เพิ่มเติม (คั่นด้วยจุลภาค) ถ้าโดเมนหน้าเว็บไม่ใช่ localhost
# CORS_ORIGIN=https://your-site.pages.dev

# —— Cloudflare Worker (wrangler secret / [vars] ใน wrangler.toml) ——
# ไม่ใช้ R2_ACCESS_KEY_* ใน Worker — ผูก bucket ใน wrangler.toml แทน ([[r2_buckets]])
# Secret: TURSO_DATABASE_URL, TURSO_AUTH_TOKEN, ADMIN_API_KEY
# Var: R2_PUBLIC_BASE_URL, (ไม่บังคับ) MAX_CASES, CORS_ORIGIN, ADMIN_WEB_PASSWORD
# Deploy: npm run deploy:cf
#
# สำหรับ wrangler dev / preview:cf — คัดลอก .dev.vars.example เป็น .dev.vars แล้วใส่ TURSO_* + ADMIN_API_KEY
