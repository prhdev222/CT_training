{
  "name": "ct-trainer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "teaching:scan": "node scripts/update-teaching-manifest.mjs",
    "server": "node -r dotenv/config server/index.mjs",
    "dev:full": "concurrently -k \"npm run server\" \"npm run dev\"",
    "deploy:cf": "npm run build && wrangler deploy",
    "preview:cf": "npm run build && wrangler dev"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@hono/node-server": "^1.13.7",
    "@libsql/client": "^0.14.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "hono": "^4.6.16",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-image-crop": "^11.0.10",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.11",
    "wrangler": "^4.80.0"
  }
}
